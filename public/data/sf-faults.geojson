ied by modern valley fill but trenching studies show that large earthquakes (magnitude 7+) have occurred on the northern part of the fault during the past 600-1400 years. For more information: San Gregorio Fault"},"geometry":{"type":"MultiLineString","coordinates":[[[-122.196709,36.900913],[-122.164632,36.826034],[-122.13792,36.771451],[-122.116895,36.716029],[-122.096159,36.667442],[-122.054682,36.603281],[-122.026358,36.558286]],[[-122.680905,37.781153],[-122.666655,37.752817],[-122.638477,37.710784],[-122.609325,37.685405],[-122.588899,37.662953],[-122.561202,37.609375],[-122.537169,37.553918],[-122.510771,37.519432],[-122.48054,37.477664],[-122.453792,37.435882],[-122.436229,37.402025],[-122.421507,37.376042],[-122.388266,37.319539],[-122.372151,37.257045],[-122.353991,37.214554],[-122.330547,37.165899],[-122.314955,37.129941],[-122.300326,37.101194],[-122.27866,37.071561],[-122.261746,37.045412],[-122.235841,37.006259],[-122.219121,36.964494],[-122.196755,36.90102]],[[-122.026186,36.558012],[-122.01239,36.535152],[-121.997482,36.509415],[-121.982222,36.478136],[-121.96437,36.437423],[-121.947017,36.413137],[-121.939265,36.399954],[-121.924865,36.376196],[-121.91301,36.359434],[-121.898467,36.348977],[-121.875488,36.338715],[-121.85135,36.322642],[-121.829034,36.295797],[-121.800069,36.263861],[-121.772853,36.234901],[-121.751956,36.209236],[-121.722267,36.173266]]]}}]}